# ─── Sanity ──────────────────────────────────────────────
# Obtener en: sanity.io → tu proyecto → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=tu_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Token con permisos de lectura (Manage → API → Tokens)
SANITY_API_TOKEN=tu_api_token

# String aleatorio para el webhook de ISR (cualquier string seguro)
SANITY_REVALIDATE_SECRET=un_string_muy_secreto

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
